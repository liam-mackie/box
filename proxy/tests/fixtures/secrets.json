{
  "secrets": [
    {
      "name": "GH_TOKEN",
      "value": "ghp_fixture_example_value",
      "injection": {
        "location": "header",
        "field": "Authorization",
        "template": "Bearer ${value}"
      },
      "scopes": [
        { "host": "api.github.com", "pathPrefix": "/repos", "pathRegex": null }
      ]
    },
    {
      "name": "SESSION",
      "value": "sess-fixture-abc123",
      "injection": {
        "location": "cookie",
        "field": "session",
        "template": "${value}"
      },
      "scopes": [
        { "host": ".example.com", "pathPrefix": null, "pathRegex": null }
      ]
    },
    {
      "name": "API_KEY",
      "value": "k/ey with spaces",
      "injection": {
        "location": "query",
        "field": "api_key",
        "template": "${value|urlencode}"
      },
      "scopes": [
        { "host": "api.example.com", "pathPrefix": null, "pathRegex": "^/v1/" }
      ]
    },
    {
      "name": "GH_PLACEHOLDER",
      "value": "ghp_placeholder_example_value",
      "injection": {
        "location": "placeholder",
        "token": "BOX_SECRET_GITHUB_TOKEN",
        "template": "${value}"
      },
      "scopes": [
        { "host": "api.github.com", "pathPrefix": null, "pathRegex": null }
      ]
    }
  ]
}
